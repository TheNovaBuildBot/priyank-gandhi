<footer>
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-section">
        <h4>About</h4>
        <p>{{ site.specialty }}</p>
        <p>{{ site.qualifications }}</p>
      </div>

      <div class="footer-section">
        <h4>Services</h4>
        <ul>
          {% for service in services %}
          <li><a href="#services">{{ service.name }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer-section">
        <h4>Contact</h4>
        <ul>
          <li><strong>Phone:</strong> <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a></li>
          <li><strong>Email:</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a></li>
          <li><strong>Location:</strong> {{ site.address_short }}</li>
        </ul>
      </div>
    </div>

    <div class="footer-divider">
      <p>&copy; 2026 {{ site.name }}. All rights reserved. | 
        <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer">LinkedIn</a> | 
        <a href="{{ site.github }}" target="_blank" rel="noopener noreferrer">GitHub</a>
      </p>
    </div>
  </div>
</footer>
