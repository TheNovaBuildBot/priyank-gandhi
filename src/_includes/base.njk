<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title or site.title }}</title>
<meta name="description" content="{{ description or site.specialty }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<meta property="og:title" content="{{ title or site.title }}">
<meta property="og:description" content="{{ description or site.specialty }}">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ title or site.title }}">
<meta name="twitter:description" content="{{ description or site.specialty }}">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Person","name":"{{ site.name }}","jobTitle":"{{ site.specialty }}","url":"{{ site.url }}","email":"{{ site.email }}","address":{"@type":"PostalAddress","addressLocality":"{{ site.city }}","addressRegion":"California","addressCountry":"US"},"sameAs":["{{ site.linkedin }}","{{ site.github }}"]}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
{% if site.ga_id %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga_id }}"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga_id }}');</script>
{% endif %}
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #FAFAFA;
  --bg-sidebar: #FFFFFF;
  --bg-card: #FFFFFF;
  --text: #1A1A1A;
  --text-secondary: #6B7280;
  --text-muted: #9CA3AF;
  --accent: #2563EB;
  --accent-light: #EFF6FF;
  --border: #E5E7EB;
  --border-light: #F3F4F6;
  --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --mono: 'JetBrains Mono', monospace;
  --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
  --radius: 12px;
  --sidebar-width: 280px;
}
html { scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--text); background: var(--bg); font-size: 15px; line-height: 1.7; -webkit-font-smoothing: antialiased; }
a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
a:hover { color: #1D4ED8; }
img { max-width: 100%; display: block; }

/* ── Two-column layout ─── */
.site-wrapper {
  display: flex;
  min-height: 100vh;
}

/* ── Left sidebar ─── */
.sidebar {
  width: var(--sidebar-width);
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
  padding: 48px 32px;
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.sidebar-profile {
  text-align: center;
  margin-bottom: 36px;
}
.profile-photo {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  margin: 0 auto 16px;
  border: 3px solid var(--border);
}
.sidebar-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
}
.sidebar-title {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}
.sidebar-nav {
  list-style: none;
  margin-bottom: 32px;
}
.sidebar-nav li { margin-bottom: 2px; }
.sidebar-nav a {
  display: block;
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.sidebar-nav a:hover,
.sidebar-nav a.active {
  background: var(--accent-light);
  color: var(--accent);
}
.sidebar-social {
  margin-top: auto;
  display: flex;
  gap: 12px;
  justify-content: center;
  padding-top: 24px;
  border-top: 1px solid var(--border-light);
}
.sidebar-social a {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  transition: all 0.2s;
}
.sidebar-social a:hover {
  background: var(--accent);
  color: white;
}
.sidebar-social svg { width: 16px; height: 16px; }

/* ── Main content ─── */
.main-content {
  margin-left: var(--sidebar-width);
  flex: 1;
  padding: 48px 56px;
  max-width: 900px;
}

/* ── Page sections ─── */
.page-section {
  margin-bottom: 56px;
}
.page-section h1 {
  font-size: 32px;
  font-weight: 700;
  margin-bottom: 8px;
  letter-spacing: -0.02em;
}
.page-section h2 {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 20px;
  color: var(--text);
  letter-spacing: -0.01em;
}
.page-section p {
  color: var(--text-secondary);
  margin-bottom: 16px;
}
.page-subtitle {
  font-size: 15px;
  color: var(--text-muted);
  margin-bottom: 40px;
}
.divider {
  width: 40px;
  height: 3px;
  background: var(--accent);
  border-radius: 2px;
  margin-bottom: 24px;
}

/* ── Cards ─── */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  margin-bottom: 16px;
  transition: box-shadow 0.2s;
}
.card:hover { box-shadow: var(--shadow-md); }
.card-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 6px;
}
.card h3 {
  font-size: 17px;
  font-weight: 600;
  margin-bottom: 4px;
}
.card .company {
  font-size: 14px;
  font-weight: 500;
  color: var(--accent);
  margin-bottom: 10px;
}
.card p { font-size: 14px; color: var(--text-secondary); margin-bottom: 0; }

/* ── Skills ─── */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 16px;
}
.skill-tag {
  background: var(--accent-light);
  color: var(--accent);
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}

/* ── Contact ─── */
.contact-links {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.contact-link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  transition: all 0.2s;
}
.contact-link:hover {
  border-color: var(--accent);
  box-shadow: var(--shadow-md);
  color: var(--text);
}
.contact-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: var(--accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.contact-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.contact-val { font-size: 14px; font-weight: 500; }

/* ── Mobile menu toggle ─── */
.mobile-toggle {
  display: none;
  position: fixed;
  top: 16px;
  left: 16px;
  z-index: 200;
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-md);
  cursor: pointer;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

/* ── Responsive ─── */
@media (max-width: 860px) {
  .mobile-toggle { display: flex; }
  .sidebar {
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 150;
    box-shadow: none;
  }
  .sidebar.open {
    transform: translateX(0);
    box-shadow: 4px 0 24px rgba(0,0,0,0.1);
  }
  .main-content {
    margin-left: 0;
    padding: 72px 24px 48px;
  }
}
</style>
</head>
<body>

<button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open')">☰</button>

<div class="site-wrapper">
  <aside class="sidebar">
    <div class="sidebar-profile">
      {% if profilePhoto %}
      <img src="{{ profilePhoto }}" alt="{{ site.name }}" class="profile-photo">
      {% endif %}
      <div class="sidebar-name">{{ site.name }}</div>
      <div class="sidebar-title">{{ site.specialty }}</div>
    </div>

    <ul class="sidebar-nav">
      <li><a href="/" {% if page.url == "/" %}class="active"{% endif %}>Home</a></li>
      <li><a href="/experience/" {% if page.url == "/experience/" %}class="active"{% endif %}>Experience</a></li>
      <li><a href="/projects/" {% if page.url == "/projects/" %}class="active"{% endif %}>Projects</a></li>
      <li><a href="/contact/" {% if page.url == "/contact/" %}class="active"{% endif %}>Contact</a></li>
    </ul>

    <div class="sidebar-social">
      <a href="{{ site.linkedin }}" target="_blank" title="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 0H4C1.8 0 0 1.8 0 4v16c0 2.2 1.8 4 4 4h16c2.2 0 4-1.8 4-4V4c0-2.2-1.8-4-4-4zM8 20H5V10h3v10zm-1.5-11.3c-1 0-1.8-.8-1.8-1.8s.8-1.8 1.8-1.8 1.8.8 1.8 1.8-.8 1.8-1.8 1.8zM20 20h-3v-5c0-1.7-.7-2.8-2.1-2.8-1.1 0-1.8.8-2.1 1.5-.1.3-.1.6-.1 1v5.3h-3V10h3v1.4c.4-.7 1.2-1.6 2.9-1.6 2.1 0 3.7 1.4 3.7 4.3V20z"/></svg>
      </a>
      <a href="{{ site.github }}" target="_blank" title="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2.9-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.3 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12 24 5.4 18.6 0 12 0z"/></svg>
      </a>
    </div>
  </aside>

  <main class="main-content">
    {{ content | safe }}
  </main>
</div>

<script>
document.querySelectorAll('.sidebar-nav a').forEach(function(link) {
  link.addEventListener('click', function() {
    document.querySelector('.sidebar').classList.remove('open');
  });
});
</script>
</body>
</html>
