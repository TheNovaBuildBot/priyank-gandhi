---
layout: base.njk
title: "Contact — Priyank Gandhi"
description: "Get in touch with Priyank Gandhi."
profilePhoto: "/assets/profile.jpg"
---

<div class="page-section">
  <h1>Contact</h1>
  <p class="page-subtitle">Feel free to reach out.</p>
  <div class="divider"></div>

  <div class="contact-links">
    <a href="mailto:{{ site.email }}" class="contact-link">
      <div class="contact-icon">✉</div>
      <div>
        <div class="contact-label">Email</div>
        <div class="contact-val">{{ site.email }}</div>
      </div>
    </a>

    <a href="{{ site.linkedin }}" target="_blank" class="contact-link">
      <div class="contact-icon">💼</div>
      <div>
        <div class="contact-label">LinkedIn</div>
        <div class="contact-val">linkedin.com/in/priyankgandhi</div>
      </div>
    </a>

    <a href="{{ site.github }}" target="_blank" class="contact-link">
      <div class="contact-icon">🔧</div>
      <div>
        <div class="contact-label">GitHub</div>
        <div class="contact-val">github.com/priyankgandhi</div>
      </div>
    </a>

    <div class="contact-link" style="cursor: default;">
      <div class="contact-icon">📍</div>
      <div>
        <div class="contact-label">Location</div>
        <div class="contact-val">{{ site.address }}</div>
      </div>
    </div>
  </div>
</div>
